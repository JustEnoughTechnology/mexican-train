[sub_resource type="GDScript" id="GDScript_1"]
script/source = "extends Control

func _ready():
	print(\"Simple experimental domino validation starting...\")
		# Try to load a white-dot SVG
	var svg_path = \"res://assets/experimental/dominos_white/white_domino-1-1_top.svg\"
	print(\"Attempting to load: \", svg_path)
	
	if ResourceLoader.exists(svg_path):
		print(\"✓ SVG file exists\")
		var texture = load(svg_path)
		if texture:
			print(\"✓ SVG loaded successfully\")
			$TextureRect.texture = texture
			print(\"✓ Texture applied to TextureRect\")
		else:
			print(\"✗ Failed to load SVG as texture\")
	else:
		print(\"✗ SVG file does not exist at path: \", svg_path)
	
	# Check shader material
	var material = $TextureRect.material
	if material and material is ShaderMaterial:
		print(\"✓ Shader material is applied\")
		var shader_mat = material as ShaderMaterial
		print(\"  - left_dots: \", shader_mat.get_shader_parameter(\"left_dots\"))
		print(\"  - right_dots: \", shader_mat.get_shader_parameter(\"right_dots\"))
		print(\"  - is_vertical: \", shader_mat.get_shader_parameter(\"is_vertical\"))
	else:
		print(\"✗ Shader material not found or wrong type\")
"

